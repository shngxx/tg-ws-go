#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

BINARY=/tmp/tg-ws-go
ARCH=mipsel
DOWNLOAD_URL="https://github.com/shngxx/tg-ws-go/releases/latest/download/tg-ws-go-${ARCH}"

FLAGS="-host 0.0.0.0 -port 1080 \
  --dc-ip 1:149.154.175.53 \
  --dc-ip 2:149.154.167.220 \
  --dc-ip 3:149.154.175.100 \
  --dc-ip 4:149.154.167.91 \
  --dc-ip 5:91.108.56.100 \
  --dc-ip 203:91.105.192.100 \
  --pool-size 0 \
  --buf-kb 32"

wait_for_network() {
    local tries=0
    while [ $tries -lt 30 ]; do
        if wget -q --timeout=5 -O /dev/null "https://github.com" 2>/dev/null; then
            return 0
        fi
        tries=$((tries + 1))
        logger -t tg-ws-go "waiting for network... ($tries/30)"
        sleep 2
    done
    logger -t tg-ws-go "ERROR: network not available after 60s"
    return 1
}

download_binary() {
    wait_for_network || return 1
    logger -t tg-ws-go "downloading binary from $DOWNLOAD_URL"
    wget -q --timeout=60 -O "${BINARY}.tmp" "$DOWNLOAD_URL" && \
        mv "${BINARY}.tmp" "$BINARY" && \
        chmod +x "$BINARY" && \
        logger -t tg-ws-go "download OK ($(du -sh $BINARY | cut -f1))"
    rm -f "${BINARY}.tmp"
}

start_service() {
    [ -x "$BINARY" ] || download_binary

    if [ ! -x "$BINARY" ]; then
        logger -t tg-ws-go "ERROR: binary not available, service not started"
        return 1
    fi

    procd_open_instance
    procd_set_param command $BINARY $FLAGS
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    logger -t tg-ws-go "started on port 1080"
}

stop_service() {
    logger -t tg-ws-go "stopped"
}

# re-download and restart: /etc/init.d/tg-ws-go update
update() {
    stop
    rm -f "$BINARY"
    start
}
